rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is an approved admin
    function isApprovedAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }
    
    // Helper to check if the current user is the hardcoded super admin
    function isSuperAdminEmail() {
      return request.auth != null && request.auth.token.email.lower() == 'gideonjackbara@gmail.com';
    }

    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if isApprovedAdmin();
    }

    match /serviceCategories/{categoryId} {
      allow get, list: if true;
      allow write: if isApprovedAdmin();
    }

    match /users/{userId} {
      // Allow anyone to create their own record during signup
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to read their own profile, or admins to read any profile
      allow get: if request.auth != null && (request.auth.uid == userId || isApprovedAdmin());
      
      // Allow the Super Admin to update their own record (to set approved: true)
      // OR allow an already approved admin to update other users (but not themselves)
      allow update: if request.auth != null && (
        (request.auth.uid == userId && isSuperAdminEmail()) || 
        (isApprovedAdmin() && userId != request.auth.uid)
      );
      
      // Only approved admins can delete users (except themselves)
      allow delete: if isApprovedAdmin() && userId != request.auth.uid;
      
      // Only approved admins can list the entire user directory
      allow list: if isApprovedAdmin();
    }
  }
}
