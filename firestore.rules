rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is an approved admin
    function isApprovedAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }
    
    // Helper to check if the current user is the hardcoded super admin
    function isSuperAdminEmail() {
      return request.auth != null && request.auth.token.email.lower() == 'gideonjackbara@gmail.com';
    }

    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if isApprovedAdmin() || isSuperAdminEmail();
    }

    match /serviceCategories/{categoryId} {
      allow get, list: if true;
      allow write: if isApprovedAdmin() || isSuperAdminEmail();
    }

    match /users/{userId} {
      // Allow anyone to create their own record during signup
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to read their own profile, or admins to read any profile
      allow get: if request.auth != null && (request.auth.uid == userId || isApprovedAdmin() || isSuperAdminEmail());
      
      // Allow the Super Admin to update any record (including their own)
      // Allow approved admins to update other users
      allow update: if request.auth != null && (
        isSuperAdminEmail() || 
        (isApprovedAdmin() && userId != request.auth.uid)
      );
      
      // Allow Super Admin or approved admins to delete users
      allow delete: if isSuperAdminEmail() || (isApprovedAdmin() && userId != request.auth.uid);
      
      // CRITICAL: Allow the Super Admin to list users so they can approve them
      allow list: if isApprovedAdmin() || isSuperAdminEmail();
    }
  }
}