rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is an approved admin
    function isApprovedAdmin() {
      return request.auth != null && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true;
    }

    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if isApprovedAdmin();
    }

    match /serviceCategories/{categoryId} {
      allow get, list: if true;
      allow write: if isApprovedAdmin();
    }

    match /users/{userId} {
      // Allow initial signup (create) if it's their own record
      allow create: if request.auth != null && request.auth.uid == userId;
      // Allow user to read their own status
      allow get: if request.auth != null && (request.auth.uid == userId || isApprovedAdmin());
      // Only approved admins can list users or update them
      allow list: if isApprovedAdmin();
      allow update, delete: if isApprovedAdmin() && userId != request.auth.uid;
    }
  }
}