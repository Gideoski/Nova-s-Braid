rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if the current user is the hardcoded admin
    function isAdminEmail() {
      return request.auth != null && request.auth.token.email.lower() == 'gideonjackbara@gmail.com';
    }

    // Helper to check if user is an approved admin
    function isApprovedAdmin() {
      return request.auth != null && 
             (isAdminEmail() || 
              (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
               get(/databases/$(database)/documents/users/$(request.auth.uid)).data.approved == true));
    }

    match /appointments/{appointmentId} {
      allow get, list: if true;
      allow create: if true;
      allow update, delete: if isApprovedAdmin();
    }

    match /serviceCategories/{categoryId} {
      allow get, list: if true;
      allow write: if isApprovedAdmin();
    }

    match /users/{userId} {
      // Allow anyone to create their own record
      allow create: if request.auth != null && request.auth.uid == userId;
      
      // Allow users to read their own profile, or admins to read any profile
      allow get: if request.auth != null && (request.auth.uid == userId || isApprovedAdmin());
      
      // Allow list for management - ONLY for approved admins
      allow list: if isApprovedAdmin();

      // Allow the Admin to update any record
      // ALSO allow users to update their own record ONLY if they are setting approved to false
      allow update: if request.auth != null && (
        isApprovedAdmin() || 
        (request.auth.uid == userId && request.resource.data.approved == false)
      );
      
      // Allow Admin to delete users (except themselves for safety)
      allow delete: if isAdminEmail() || (isApprovedAdmin() && userId != request.auth.uid);
    }
  }
}
