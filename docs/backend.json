
{
  "entities": {
    "Appointment": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "Appointment",
      "type": "object",
      "description": "Represents a booked appointment for a braiding service.",
      "properties": {
        "dateTime": {
          "type": "string",
          "description": "Start date and time of the appointment in ISO format.",
          "format": "date-time"
        },
        "totalCost": {
          "type": "number",
          "description": "The total cost of the appointment."
        },
        "attendees": {
          "type": "array",
          "description": "List of people attending the appointment.",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "phone": { "type": "string" },
              "services": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "name": { "type": "string" },
                    "quantity": { "type": "number" },
                    "price": { "type": "number" }
                  },
                  "required": ["name", "quantity", "price"]
                }
              }
            },
            "required": ["name", "phone", "services"]
          }
        }
      },
      "required": [
        "dateTime",
        "attendees",
        "totalCost"
      ]
    },
    "ServiceCategory": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "title": "ServiceCategory",
      "type": "object",
      "description": "Represents a category of services offered.",
      "properties": {
        "name": { "type": "string" },
        "services": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "price": { "type": "number" },
              "originalPrice": { "type": "number", "description": "The price before any discount was applied." }
            },
            "required": ["name", "price"]
          }
        }
      },
      "required": ["name", "services"]
    },
    "AdminUser": {
      "title": "AdminUser",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "approved": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "auth": {
    "providers": [
      "email"
    ]
  },
  "firestore": {
    "/appointments/{appointmentId}": {
      "schema": {
        "$ref": "#/backend/entities/Appointment"
      },
      "description": "Stores all booked appointments."
    },
    "/serviceCategories/{categoryId}": {
      "schema": {
        "$ref": "#/backend/entities/ServiceCategory"
      },
      "description": "Stores the dynamic list of service categories."
    },
    "/users/{userId}": {
      "schema": {
        "$ref": "#/backend/entities/AdminUser"
      },
      "description": "Stores administrative user permissions."
    }
  }
}
